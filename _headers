# Netlify / Cloudflare Pages headers — sécurité + perf

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.lemonsqueezy.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://api.openai.com https://api.groq.com https://api.x.ai https://api.mistral.ai https://openrouter.ai https://r.jina.ai; frame-src https://*.lemonsqueezy.com

# Cache statique long pour assets immuables
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/og-image.svg
  Cache-Control: public, max-age=31536000, immutable
/style.css
  Cache-Control: public, max-age=86400, must-revalidate

# JSON / sitemap : cache court
/sitemap.xml
  Cache-Control: public, max-age=3600
/manifest.json
  Cache-Control: public, max-age=86400
